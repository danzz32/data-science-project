# =====================================================================
# 1. AMBIENTE VIRTUAL, CONFIGURAÇÕES E IDEs
# =====================================================================
__pycache__/
*.py[oc]
*.egg-info/
.venv/
.uv/
.vulture_ignore
.Python
dist/
build/
wheels/

# ==========================================
# 2. GOVERNANÇA E SEGURANÇA (Regra de Desclassificação)
# ==========================================
# Ignora qualquer vazamento de credencial local
.env
.env.*
*.env
!.env.example

# Credenciais Kaggle / cloud (nunca versionar)
kaggle.json
**/kaggle.json
.kaggle/
credentials.json
**/credentials.json
*.pem
*.p12
*.key

# Ignora configurações locais de IDE (preferências pessoais, credenciais)
.vscode/settings.json
.vscode/launch.json
.vscode/*.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.cursor/

# Ignora segredos locais do Streamlit (chaves/API tokens de runtime)
.streamlit/secrets.toml

# Caches de lint/type-check/test/cobertura
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.Hypothesis/

# ==========================================
# 3. CAMADAS DO DATA LAKE LOCAL (Controle Estrito)
# ==========================================
# Qualquer artefato de dados nas camadas (regeneráveis pelo pipeline)
data/**/*.csv
data/**/*.zip
data/**/*.json
data/**/*.txt
data/**/*.parquet
data/**/*.duckdb
data/**/*.wal
data/raw/temp_extraction/

# Mantém apenas a estrutura de pastas versionada
!data/**/.gitkeep

# ==========================================
# 4. NOTEBOOKS E DOCUMENTAÇÃO (Estrutura Exigida)
# ==========================================
!docs/
!docs/*.qmd
!docs/*.ipynb
!docs/*.md

# Ignora caches locais do Quarto/Jupyter e temp do DuckDB
.markdown-notebook/
.ipynb_checkpoints/
docs/.tmp/
docs/.tmp/**

# ==========================================
# 5. ARTEFATOS DE BUILD E EXECUÇÃO
# ==========================================
*.log
logs/

*.tmp
*.temp
.tmp/
*.bak
*.orig

/.quarto/
**/*.quarto_ipynb
**/_freeze/

# Arquivos temporários de editores (Vim / Neovim)
*.un~
.netrwhist

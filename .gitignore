# =====================================================================
# 1. AMBIENTE VIRTUAL, CONFIGURAÇÕES E IDEs
# =====================================================================
__pycache__/
*.py[oc]
.venv/
.uv/
.vulture_ignore

# ==========================================
# 2. GOVERNANÇA E SEGURANÇA (Regra de Desclassificação)
# ==========================================
# Ignora qualquer vazamento de credencial local
.env
.env.*
*.env

# Permite explicitamente o arquivo de exemplo exigido no seu README
!.env.example

# Ignora configurações locais de IDE (preferências pessoais, credenciais)
.vscode/settings.json
.vscode/launch.json
.vscode/*.json

# Ignora arquivos de configuração local de editors
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Ignora segredos locais do Streamlit (chaves/API tokens de runtime)
.streamlit/secrets.toml

# Caches de lint/type-check/test
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ==========================================
# 3. CAMADAS DO DATA LAKE LOCAL (Controle Estrito)
# ==========================================

# --- CAMADA RAW ---
data/raw/*.csv
data/raw/*.zip
data/raw/*.json
data/raw/*.txt
!data/raw/.gitkeep

# --- CAMADA TRUSTED ---
# Ignora a saída binária de dados gerada pelo transform.py
data/trusted/*.parquet
!data/trusted/.gitkeep

# --- CAMADA QUARANTINE ---
# Ignora os arquivos binários de isolamento, mas mantém a pasta
data/quarantine/*.parquet
!data/quarantine/.gitkeep

# --- CAMADA MART ---
# Ignora a saída binária gerada pelo build_mart.py (regenerável a partir da camada trusted)
data/mart/*.parquet
!data/mart/.gitkeep

# ==========================================
# 4. NOTEBOOKS E DOCUMENTAÇÃO (Estrutura Exigida)
# ==========================================
# Garante que o notebook eda_qualidade.qmd e scripts não sejam ignorados
!docs/
!docs/*.qmd
!docs/*.ipynb

# Ignora caches locais do Quarto/Jupyter se você renderizar os relatórios
.markdown-notebook/
.ipynb_checkpoints/

# ==========================================
# 5. ARTEFATOS DE BUILD E EXECUÇÃO
# ==========================================
# Logs de execução
*.log
logs/

# Arquivos temporários
*.tmp
*.temp
.tmp/
docs/.tmp

/.quarto/
**/*.quarto_ipynb


# Arquivos temporários de editores (Vim / Neovim)
*.un~
*.swp
*.swo
.netrwhist
